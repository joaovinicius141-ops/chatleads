# Token da pagina do Facebook (painel do Messenger)
PAGE_ACCESS_TOKEN=cole_aqui_o_token_da_pagina

# Senha que voce inventou na configuracao do Webhook
VERIFY_TOKEN=meu_token_secreto

# Chave da API do Gemini (aistudio.google.com)
GEMINI_API_KEY=cole_aqui_a_chave_gemini

# Modelo do Gemini (nao precisa mudar)
GEMINI_MODEL=gemini-2.5-flash

# Token do Mercado Pago (mercadopago.com.br > Credenciais > Access Token de PRODUCAO)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...

# URL publica do Railway (ex: https://chatleads-production.up.railway.app)
# Usada para o Mercado Pago enviar o webhook de pagamento confirmado
PUBLIC_URL=https://chatleads-production.up.railway.app

# Email da empresa exibido no comprovante PIX
EMAIL_EMPRESA=pagamento@crieseuconstrato.com.br

# Porta do servidor (Railway define automaticamente)
PORT=3000
