# Token da pagina do Facebook (painel do Messenger)
PAGE_ACCESS_TOKEN=cole_aqui_o_token_da_pagina

# Senha que voce inventou na configuracao do Webhook
VERIFY_TOKEN=meu_token_secreto

# Chave da API do Gemini (aistudio.google.com)
GEMINI_API_KEY=cole_aqui_a_chave_gemini

# Modelo do Gemini (nao precisa mudar)
GEMINI_MODEL=gemini-2.5-flash

# Token do Mercado Pago (mercadopago.com.br > Credenciais > Access Token de PRODUCAO)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...

# URL publica do Railway (ex: https://chatleads-production.up.railway.app)
# Usada para o Mercado Pago enviar o webhook de pagamento confirmado
PUBLIC_URL=https://chatleads-production.up.railway.app

# Email da empresa exibido no comprovante PIX
EMAIL_EMPRESA=pagamento@crieseuconstrato.com.br

# Porta do servidor (Railway define automaticamente)
PORT=3000

# ── Contato humano (Pedro) ─────────────────────────────────
# WhatsApp exibido ao cliente em caso de falha ou fora do escopo do bot
WHATSAPP_PEDRO=(11) 99999-0000

# Janela em que o bot passa o numero direto.
# Fora dessa janela, orienta o cliente a mandar mensagem para ser respondida depois.
HORARIO_INICIO=8
HORARIO_FIM=22
TIMEZONE=America/Sao_Paulo

# ── Seguranca ──────────────────────────────────────────────
# Segredo do app do Facebook (validacao da assinatura do webhook)
FB_APP_SECRET=cole_aqui_o_app_secret_da_pagina

# Segredo do webhook do Mercado Pago (painel > notificacoes)
MP_WEBHOOK_SECRET=cole_aqui_o_secret_do_webhook

# Senha do endpoint /aprovar-teste (use algo longo e aleatorio; REMOVA em producao)
TESTE_SECRET=troque_esse_valor

# Senha dos endpoints administrativos /admin/* (consulta de documentos, logs, stats)
ADMIN_SECRET=troque_esse_valor_por_algo_aleatorio_longo

# Ambiente (production bloqueia /aprovar-teste e exige FB_APP_SECRET)
NODE_ENV=production

# ── Retencao de arquivos ───────────────────────────────────
# Dias que documentos gerados e logs ficam no servidor antes de serem apagados
DIAS_RETENCAO=30

# ── WhatsApp Cloud API (opcional — deixe vazio se nao for usar) ─
# Quando preenchido, o webhook /webhook/whatsapp e registrado automaticamente
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=
WA_APP_SECRET=
